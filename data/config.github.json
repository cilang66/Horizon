{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "",
    "smtp_port": 465,
    "imap_server": "",
    "imap_port": 993,
    "email_address": ""
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "comfyanonymous",
        "repo": "ComfyUI",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "Stability-AI",
        "repo": "stablediffusion",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "runwayml",
        "repo": "stable-diffusion",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "AUTOMATIC1111",
        "repo": "stable-diffusion-webui",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "sora",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "TencentARC",
        "repo": "AnimateDiff",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "llychao",
        "repo": "Awesome-Text2Video",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "lllyasviel",
        "repo": "Fooocus",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "Lightricks",
        "repo": "LTX-Video",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Stability AI Blog",
        "url": "https://stability.ai/blogs/rss.xml",
        "enabled": true,
        "category": "image-model"
      },
      {
        "name": "RunwayML Blog",
        "url": "https://runwayml.com/blog/feed.xml",
        "enabled": true,
        "category": "video-model"
      },
      {
        "name": "Hugging Face - Diffusion Models",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "image-model"
      },
      {
        "name": "ArXiv - cs.CV (Computer Vision)",
        "url": "https://rss.arxiv.org/rss/cs.CV",
        "enabled": true,
        "category": "aigc-research",
        "fetch_limit": 15
      },
      {
        "name": "ArXiv - cs.GR (Graphics)",
        "url": "https://rss.arxiv.org/rss/cs.GR",
        "enabled": true,
        "category": "aigc-research",
        "fetch_limit": 10
      },
      {
        "name": "ArXiv - cs.MM (Multimedia)",
        "url": "https://rss.arxiv.org/rss/cs.MM",
        "enabled": true,
        "category": "aigc-research",
        "fetch_limit": 10
      },
      {
        "name": "TechCrunch - AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "aigc-news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "StableDiffusion",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "StableDiffusionTutorials",
          "enabled": true,
          "sort": "hot",
          "time_filter": "week",
          "fetch_limit": 10,
          "min_score": 10
        },
        {
          "subreddit": "ComfyUI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "aivideo",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 10
        },
        {
          "subreddit": "AIArtist",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 20
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "twitter": {
      "enabled": true,
      "users": ["StabilityAI", "RunwayML", "comfy_org", "Civitai", "lily_ai_art", "growing_ai_art", "ai_video_tools", "Kling_ai", "Pika_Labs"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": ["aigc", "stable-diffusion", "comfyui", "flux", "midjourney", "image-generation", "video-generation", "sora", "runway", "kling", "pika", "text-to-video", "text-to-image", "image-to-video", "diffusion", "controlnet", "lora", "ip-adapter", "upscale", "inpainting", "outpainting", "animatediff", "latent-consistency", "sdxl", "sd3", "sd-turbo", "hunyuan-video", "cogvideo", "wan-video"],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 30,
    "category_groups": {
      "aigc-news": {
        "name": "AIGC资讯",
        "limit": 5,
        "categories": ["aigc-news", "aigc-tool", "aigc-research"]
      },
      "image-model": {
        "name": "AI生图·模型工具",
        "limit": 6,
        "categories": ["image-model"]
      },
      "image-tutorial": {
        "name": "AI生图·教程案例",
        "limit": 6,
        "categories": ["image-tutorial", "image-showcase"]
      },
      "video-model": {
        "name": "AI视频·模型工具",
        "limit": 5,
        "categories": ["video-model"]
      },
      "video-tutorial": {
        "name": "AI视频·教程案例",
        "limit": 5,
        "categories": ["video-tutorial", "video-showcase"]
      },
      "prompt": {
        "name": "提示词教程",
        "limit": 5,
        "categories": ["prompt-tutorial"]
      }
    },
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": false
  }
}
