{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "",
    "smtp_port": 465,
    "imap_server": "",
    "imap_port": 993,
    "email_address": ""
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "ggerganov",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "jackfrued",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-cookbook",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "deepseek-ai",
        "repo": "DeepSeek-V3",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langgenius",
        "repo": "dify",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "n8n-io",
        "repo": "n8n",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "vscode",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "TechCrunch - AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "ArXiv - cs.AI",
        "url": "https://rss.arxiv.org/rss/cs.AI",
        "enabled": true,
        "category": "ai-research",
        "fetch_limit": 15
      },
      {
        "name": "ArXiv - cs.CL (NLP)",
        "url": "https://rss.arxiv.org/rss/cs.CL",
        "enabled": true,
        "category": "ai-research",
        "fetch_limit": 15
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "MIT Tech Review - AI",
        "url": "https://www.technologyreview.com/topic/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "VentureBeat - AI",
        "url": "https://venturebeat.com/category/ai/feed/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Ars Technica - AI",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "ai-news"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "users": [],
      "fetch_comments": 3
    },
    "twitter": {
      "enabled": true,
      "users": ["karpathy", "ylecun", "amasad", "sama", "rauchg", "jim_fan_", "dr_cintas", "nickfloats", "ai_npc1"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": ["llm", "agent", "ai", "gpt", "rag", "embedding", "diffusion", "transformer"],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 48,
    "max_items": null,
    "category_groups": {},
    "default_group": "other",
    "default_group_limit": null
  },
  "webhook": {
    "enabled": false
  }
}
